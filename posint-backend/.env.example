# ─── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database (Neon PostgreSQL) ──────────────────────────
# Pooled connection (application queries via PgBouncer)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/posint?sslmode=require&pgbouncer=true&connection_limit=10"

# Direct connection (Prisma migrations only — never use in app code)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/posint?sslmode=require"

# ─── Redis (Upstash) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# For BullMQ (ioredis-compatible, NOT the REST client)
REDIS_HOST=xxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# ─── Pusher ──────────────────────────────────────────────
PUSHER_APP_ID=1234567
NEXT_PUBLIC_PUSHER_KEY=abc123def456
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=eu

# ─── Anthropic (NLP / Sentiment — preferred over OpenAI) ─
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (NLP / Sentiment) ────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Social Media ────────────────────────────────────────
TWITTER_BEARER_TOKEN=AAA...

# ─── Throttling ──────────────────────────────────────────
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=60000
THROTTLE_MEDIUM_LIMIT=100

# ─── Proxy rotation (optional) ───────────────────────────
# Comma-separated list: host:port:user:pass
PROXY_LIST=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
